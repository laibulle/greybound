{
  schema: "greybound.circuit-diagram.v1",
  model: "nox30",
  title: "Nox30 amp documentation graph",
  status: "documentation",
  sourceOfTruth: "rust-model",

  renderer: {
    layout: "left-to-right",
    preferredWidth: 1800,
    preferredHeight: 820,
  },

  groups: [
    {
      id: "preamp",
      label: "Top Boost preamp",
      nodes: [
        "input_volume",
        "first_triode",
        "cathode_follower",
        "tone_stack",
        "drive_stage",
        "recovery_stage",
      ],
    },
    {
      id: "power",
      label: "Phase inverter and power amp",
      nodes: [
        "phase_inverter",
        "cut_presence",
        "el84_power",
        "supply_network",
        "output_transformer",
      ],
    },
  ],

  nodes: [
    {
      id: "input_volume",
      label: "Bright volume",
      kind: "potentiometer",
      ports: ["in", "out"],
      hardware: {
        role: "500 kOhm volume control with bright bypass capacitor",
        parts: ["500 kOhm potentiometer", "100 pF bright capacitor"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/passive.rs::BrightVolumeInputStage",
        library: ["BrightVolumeInputStage", "BrightVolumeInputParams"],
        state: ["input_volume"],
        algorithm: "frequency-dependent volume and bright-cap feed into the first triode",
      },
      spice: null,
      layout: { x: 60, y: 310 },
    },
    {
      id: "first_triode",
      label: "First ECC83 stage",
      kind: "triode_stage",
      ports: ["in", "out", "supply"],
      hardware: {
        role: "common-cathode Top Boost gain stage",
        parts: [
          "ECC83 / 12AX7",
          "100 kOhm plate resistor",
          "1.5 kOhm cathode resistor",
          "25 uF bypass capacitor",
        ],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/triode.rs::CommonCathodeStage",
        library: ["CommonCathodeStage"],
        state: ["first_stage"],
        algorithm: "nonlinear triode approximation with cathode-bypass response and operating-point telemetry",
      },
      spice: null,
      layout: { x: 250, y: 310 },
    },
    {
      id: "cathode_follower",
      label: "Cathode follower",
      kind: "triode_follower",
      ports: ["in", "out", "supply"],
      hardware: {
        role: "low impedance drive into passive Top Boost tone stack",
        parts: ["ECC83 / 12AX7 cathode follower"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/triode.rs::CathodeFollowerStage",
        library: ["CathodeFollowerStage"],
        state: ["follower"],
        algorithm: "low-distortion follower with grid-current recovery behavior",
      },
      spice: null,
      layout: { x: 450, y: 310 },
    },
    {
      id: "tone_stack",
      label: "Top Boost tone stack",
      kind: "mna_network",
      ports: ["in", "out"],
      hardware: {
        role: "interactive bass/treble passive network",
        parts: [
          "1 MOhm treble pot",
          "1 MOhm bass pot",
          "50 pF treble cap",
          "2 x 22 nF bass caps",
          "100 kOhm slope path",
          "10 kOhm bass ground path",
        ],
        confidence: "high",
      },
      emulation: {
        implementation: "core/src/amp/components.rs::TopBoostToneStack",
        library: ["TopBoostToneStack"],
        state: ["tone_stack"],
        algorithm: "seven-node trapezoidal Modified Nodal Analysis passive solve",
      },
      spice: null,
      layout: { x: 660, y: 310 },
    },
    {
      id: "drive_stage",
      label: "Drive stage",
      kind: "triode_stage",
      ports: ["in", "out", "supply"],
      hardware: {
        role: "extra graybox drive stage used by current Nox30 model",
        confidence: "inferred",
      },
      emulation: {
        implementation: "core/src/amp/models/nox30.rs::Nox30",
        library: ["CommonCathodeStage"],
        state: ["drive_stage"],
        algorithm: "control-dependent hot triode stage blended with tone-stack output",
      },
      spice: null,
      layout: { x: 890, y: 220 },
    },
    {
      id: "recovery_stage",
      label: "Recovery stage",
      kind: "triode_stage",
      ports: ["in", "out", "supply"],
      hardware: {
        role: "post-drive recovery gain",
        confidence: "inferred",
      },
      emulation: {
        implementation: "core/src/amp/models/nox30.rs::Nox30",
        library: ["CommonCathodeStage"],
        state: ["recovery_stage"],
        algorithm: "drive-dependent recovery stage before phase-inverter coupling",
      },
      spice: null,
      layout: { x: 1080, y: 220 },
    },
    {
      id: "phase_inverter",
      label: "Long-tail pair",
      kind: "phase_inverter",
      ports: ["in", "phase_a", "phase_b", "supply"],
      hardware: {
        role: "ECC83 / 12AX7 long-tail-pair phase inverter",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/triode.rs::LongTailPairStage",
        library: ["LongTailPairStage", "WdfHighpass"],
        state: ["phase_inverter_coupling", "phase_inverter"],
        algorithm: "coupled high-pass into nonlinear opposing triode phases",
      },
      spice: null,
      layout: { x: 1280, y: 310 },
    },
    {
      id: "cut_presence",
      label: "Cut / presence",
      kind: "tone_control",
      ports: ["phase_a", "phase_b", "out_a", "out_b"],
      hardware: {
        role: "high-frequency cut across opposed phase-inverter outputs",
        parts: ["500 kOhm cut pot", "4.7 nF capacitor"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/passive.rs::CutPresenceStage",
        library: ["CutPresenceStage"],
        state: ["cut_presence"],
        algorithm: "phase-output high-frequency shaping before power stage",
      },
      spice: null,
      layout: { x: 1480, y: 310 },
    },
    {
      id: "el84_power",
      label: "EL84 push-pull power stage",
      kind: "power_stage",
      ports: ["phase_a", "phase_b", "out", "supply"],
      hardware: {
        role: "four EL84 cathode-biased push-pull output section",
        parts: [
          "4 x EL84",
          "50 Ohm shared cathode resistor",
          "250 uF bypass capacitor",
        ],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/power.rs::PushPullEl84Stage",
        library: ["PushPullEl84Stage"],
        state: ["power_stage"],
        algorithm: "push-pull saturation, dynamic cathode bias shift, screen-current telemetry",
      },
      spice: null,
      layout: { x: 1700, y: 310 },
    },
    {
      id: "supply_network",
      label: "B+ supply and sag",
      kind: "supply",
      ports: ["preamp", "phase_inverter", "power"],
      hardware: {
        role: "shared B+ rails and dynamic sag behavior",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/power.rs::SupplyNetwork",
        library: ["SupplyNetwork"],
        state: ["supply"],
        algorithm: "rail voltage recovery and current-dependent sag",
      },
      spice: null,
      layout: { x: 1180, y: 620 },
    },
    {
      id: "output_transformer",
      label: "Output transformer",
      kind: "transformer",
      ports: ["in", "speaker"],
      hardware: {
        role: "output transformer and speaker coupling",
        value: "about 4 kOhm primary target",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/circuit/power.rs::OutputTransformerStage",
        library: ["OutputTransformerStage"],
        state: ["output_transformer"],
        algorithm: "transformer filtering and core-flux compression state",
      },
      spice: null,
      layout: { x: 1920, y: 310 },
    },
  ],

  edges: [
    {
      from: "input_volume.out",
      to: "first_triode.in",
      signal: "audio_voltage",
    },
    {
      from: "first_triode.out",
      to: "cathode_follower.in",
      signal: "triode_output",
    },
    {
      from: "cathode_follower.out",
      to: "tone_stack.in",
      signal: "low_impedance_drive",
    },
    { from: "tone_stack.out", to: "drive_stage.in", signal: "toned_audio" },
    {
      from: "drive_stage.out",
      to: "recovery_stage.in",
      signal: "driven_audio",
    },
    {
      from: "recovery_stage.out",
      to: "phase_inverter.in",
      signal: "recovered_audio",
    },
    {
      from: "phase_inverter.phase_a",
      to: "cut_presence.phase_a",
      signal: "phase_a",
    },
    {
      from: "phase_inverter.phase_b",
      to: "cut_presence.phase_b",
      signal: "phase_b",
    },
    {
      from: "cut_presence.out_a",
      to: "el84_power.phase_a",
      signal: "shaped_phase_a",
    },
    {
      from: "cut_presence.out_b",
      to: "el84_power.phase_b",
      signal: "shaped_phase_b",
    },
    {
      from: "el84_power.out",
      to: "output_transformer.in",
      signal: "power_output",
    },
    {
      from: "supply_network.preamp",
      to: "first_triode.supply",
      signal: "b_plus",
    },
    {
      from: "supply_network.phase_inverter",
      to: "phase_inverter.supply",
      signal: "b_plus",
    },
    { from: "supply_network.power", to: "el84_power.supply", signal: "b_plus" },
  ],

  annotations: [
    {
      text: "Nox30 diagram is stage-level. Component-exact SPICE export is intentionally empty until selected subcircuits are promoted to concrete parts.",
    },
  ],
}
