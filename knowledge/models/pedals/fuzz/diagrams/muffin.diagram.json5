{
  schema: "greybound.circuit-diagram.v1",
  model: "muffin",
  title: "Muffin fuzz documentation graph",
  status: "documentation",
  sourceOfTruth: "rust-model",

  renderer: {
    layout: "left-to-right",
    preferredWidth: 1500,
    preferredHeight: 780,
  },

  groups: [
    {
      id: "input",
      label: "Input and booster",
      nodes: ["input_jack", "input_load", "input_coupling", "input_booster"],
    },
    {
      id: "clipping",
      label: "Cascaded clipping stages",
      nodes: ["clip_stage_a", "diodes_a", "clip_stage_b", "diodes_b"],
    },
    {
      id: "tone",
      label: "Tone and recovery",
      nodes: [
        "tone_lowpass",
        "tone_highpass",
        "tone_blend",
        "recovery_stage",
        "output_coupling",
      ],
    },
  ],

  nodes: [
    {
      id: "input_jack",
      label: "Input jack",
      kind: "connector",
      ports: ["out"],
      hardware: { role: "guitar or previous pedal input", confidence: "high" },
      emulation: { implementation: "core/src/pedal.rs::ElectricalSignal" },
      spice: null,
      layout: { x: 40, y: 320 },
    },
    {
      id: "input_load",
      label: "Input load",
      kind: "load",
      ports: ["in", "out"],
      hardware: {
        role: "pedal input impedance and cable capacitance boundary",
        value: "about 117 kOhm target, 130 kOhm current DSP",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        library: ["ConnectionState", "Load"],
        state: ["input_connection"],
        algorithm: "source/load division with 470 pF cable capacitance memory",
      },
      spice: {
        primitive: "R",
        name: "Rin",
        nodes: ["in", "0"],
        value: "130k",
      },
      layout: { x: 210, y: 300 },
    },
    {
      id: "input_coupling",
      label: "Input coupling",
      kind: "highpass",
      ports: ["in", "out"],
      hardware: {
        role: "DC blocking and low cut before the transistor stages",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        library: ["OnePoleHighpass"],
        state: ["input_coupling"],
        algorithm: "7 Hz one-pole high-pass",
      },
      spice: null,
      layout: { x: 380, y: 300 },
    },
    {
      id: "input_booster",
      label: "Input booster",
      kind: "bjt_stage",
      ports: ["in", "out"],
      hardware: {
        role: "first common-emitter booster",
        parts: [
          "silicon NPN",
          "collector resistor",
          "emitter resistor",
          "feedback resistor",
        ],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin::common_emitter_stage",
        library: ["OnePoleLowpass", "transistor_limit"],
        state: ["stage_filters[0]"],
        algorithm: "filtered inverted gain stage with transistor limiting",
      },
      spice: null,
      layout: { x: 560, y: 300 },
    },
    {
      id: "clip_stage_a",
      label: "Clipping stage A",
      kind: "bjt_stage",
      ports: ["in", "out"],
      hardware: {
        role: "first high-gain clipping amplifier",
        parts: ["silicon NPN common-emitter stage"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin::common_emitter_stage",
        state: ["stage_filters[1]"],
        algorithm: "gain rises with sustain before diode-pair clipping",
      },
      spice: null,
      layout: { x: 740, y: 220 },
    },
    {
      id: "diodes_a",
      label: "Diode pair A",
      kind: "diode_pair",
      ports: ["in", "out"],
      hardware: {
        role: "antiparallel silicon clipping diodes",
        value: "1N914/1N4148-equivalent target",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::diode_pair_clip",
        algorithm: "0.42 V tanh soft clip",
      },
      spice: {
        primitive: "DPAIR",
        name: "DclipA",
        nodes: ["clip_a", "clip_a_out"],
        model: "silicon_soft_clip",
        params: { vf: 0.42 },
      },
      layout: { x: 900, y: 220 },
    },
    {
      id: "clip_stage_b",
      label: "Clipping stage B",
      kind: "bjt_stage",
      ports: ["in", "out"],
      hardware: {
        role: "second high-gain clipping amplifier",
        parts: ["silicon NPN common-emitter stage"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin::common_emitter_stage",
        state: ["stage_filters[2]"],
        algorithm: "second sustain-dependent gain stage",
      },
      spice: null,
      layout: { x: 1060, y: 220 },
    },
    {
      id: "diodes_b",
      label: "Diode pair B",
      kind: "diode_pair",
      ports: ["in", "out"],
      hardware: {
        role: "second antiparallel silicon clipping pair",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::diode_pair_clip",
        algorithm: "0.42 V tanh soft clip",
      },
      spice: {
        primitive: "DPAIR",
        name: "DclipB",
        nodes: ["clip_b", "clip_b_out"],
        model: "silicon_soft_clip",
        params: { vf: 0.42 },
      },
      layout: { x: 1220, y: 220 },
    },
    {
      id: "tone_lowpass",
      label: "Tone low-pass branch",
      kind: "filter",
      ports: ["in", "out"],
      hardware: {
        role: "low branch of the passive mid-scooped tone stack",
        parts: ["39 kOhm resistor", "10 nF capacitor"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        library: ["OnePoleLowpass"],
        state: ["tone_lowpass"],
        algorithm: "720 Hz low-pass branch",
      },
      spice: null,
      layout: { x: 1380, y: 150 },
    },
    {
      id: "tone_highpass",
      label: "Tone high-pass branch",
      kind: "filter",
      ports: ["in", "out"],
      hardware: {
        role: "high branch of the passive mid-scooped tone stack",
        parts: ["3.9 nF capacitor", "22 kOhm resistor"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        library: ["OnePoleHighpass"],
        state: ["tone_highpass"],
        algorithm: "1.25 kHz high-pass branch",
      },
      spice: null,
      layout: { x: 1380, y: 330 },
    },
    {
      id: "tone_blend",
      label: "Tone blend",
      kind: "potentiometer",
      ports: ["low", "high", "out"],
      hardware: {
        role: "100 kOhm tone potentiometer blending low and high branches",
        value: "100 kOhm target",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        algorithm: "low * (1 - tone) + high * tone",
      },
      spice: null,
      layout: { x: 1560, y: 250 },
    },
    {
      id: "recovery_stage",
      label: "Recovery stage",
      kind: "bjt_stage",
      ports: ["in", "out"],
      hardware: {
        role: "post-tone recovery and level stage",
        parts: ["silicon NPN common-emitter stage", "volume control"],
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin::common_emitter_stage",
        state: ["stage_filters[3]"],
        algorithm: "level-dependent recovery gain then output volume scaling",
      },
      spice: null,
      layout: { x: 1740, y: 250 },
    },
    {
      id: "output_coupling",
      label: "Output coupling",
      kind: "highpass",
      ports: ["in", "out"],
      hardware: {
        role: "output DC blocking and source impedance boundary",
        value: "about 25 kOhm published target, 10 kOhm current DSP",
        confidence: "medium",
      },
      emulation: {
        implementation: "core/src/pedal.rs::Muffin",
        library: ["OnePoleHighpass", "ElectricalSignal"],
        state: ["output_coupling"],
        algorithm: "16 Hz high-pass, emit 10 kOhm source impedance",
      },
      spice: {
        primitive: "R",
        name: "Rout",
        nodes: ["out_src", "out"],
        value: "10k",
      },
      layout: { x: 1920, y: 250 },
    },
  ],

  edges: [
    {
      from: "input_jack.out",
      to: "input_load.in",
      signal: "audio_voltage",
      spiceNet: "in",
    },
    {
      from: "input_load.out",
      to: "input_coupling.in",
      signal: "loaded_audio_voltage",
    },
    {
      from: "input_coupling.out",
      to: "input_booster.in",
      signal: "coupled_audio",
    },
    {
      from: "input_booster.out",
      to: "clip_stage_a.in",
      signal: "boosted_audio",
    },
    { from: "clip_stage_a.out", to: "diodes_a.in", signal: "amplified_audio" },
    { from: "diodes_a.out", to: "clip_stage_b.in", signal: "clipped_audio" },
    { from: "clip_stage_b.out", to: "diodes_b.in", signal: "amplified_audio" },
    { from: "diodes_b.out", to: "tone_lowpass.in", signal: "clipped_audio" },
    { from: "diodes_b.out", to: "tone_highpass.in", signal: "clipped_audio" },
    { from: "tone_lowpass.out", to: "tone_blend.low", signal: "low_branch" },
    { from: "tone_highpass.out", to: "tone_blend.high", signal: "high_branch" },
    { from: "tone_blend.out", to: "recovery_stage.in", signal: "tone_output" },
    {
      from: "recovery_stage.out",
      to: "output_coupling.in",
      signal: "recovered_audio",
    },
  ],

  annotations: [
    {
      text: "This graph documents the current DSP and reverse-engineering target; component-exact BJT stages are future work.",
    },
  ],
}
