  amp: {
    model: 'nox30',
    bypassed: false,
    controls: {
      volume: 0.56,
      bass: 0.53,
      treble: 0.58,
      cut: 0.42,
      drive: 0.20,
      presence: 0.34,
      sag: 0.42,
    },
  },
}
