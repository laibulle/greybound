{
  // Rig only: no input device, output device, monitor, or render settings.
  name: "lumen-nox30",

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: "opto-compressor",
      device: "lumen",
      bypassed: false,
      controls: {
        peak_reduction: 0.66,
        gain: 0.52,
        emphasis: 0.48,
        mix: 0.86,
      },
    },
  ],

  amp: {
    model: "nox30",
    bypassed: false,
    controls: {
      volume: 0.55,
      bass: 0.52,
      treble: 0.60,
      cut: 0.42,
      drive: 0.14,
      presence: 0.34,
      sag: 0.42,
    },
  },

  cab: {
    ir: "embedded-v30",
    bypassed: false,
  },
}
