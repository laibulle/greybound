{
  // Rig only: no input device, output device, monitor, or render settings.
  name: 'tron-nox30',

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: 'organic-phaser',
      device: 'tron',
      bypassed: false,
      controls: {
        rate_hz: 0.68,
        depth: 0.90,
        feedback: 0.62,
        mix: 0.82,
      },
    },
  ],

  amp: {
    model: 'nox30',
    bypassed: false,
    controls: {
      volume: 0.54,
      bass: 0.52,
      treble: 0.60,
      cut: 0.43,
      drive: 0.18,
      presence: 0.32,
      sag: 0.44,
    },
  },

  cab: {
    ir: 'embedded-v30',
    bypassed: false,
  },
}
