{
  // Rig only: no input device, output device, monitor, or render settings.
  // Full board reference: every current pedal is present but bypassed.
  name: "nox30-all-pedals-bypassed",

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: "opto-compressor",
      device: "lumen",
      bypassed: true,
      controls: {
        peak_reduction: 0.66,
        gain: 0.52,
        emphasis: 0.48,
        mix: 0.86,
      },
    },
    {
      id: "envelope-filter",
      device: "muon",
      bypassed: true,
      controls: {
        sensitivity: 0.64,
        range: 0.68,
        resonance: 0.52,
        mix: 0.86,
      },
    },
    {
      id: "organic-phaser",
      device: "tron",
      bypassed: true,
      controls: {
        rate_hz: 0.68,
        depth: 0.9,
        feedback: 0.62,
        mix: 0.82,
      },
    },
    {
      id: "bbd-flanger",
      device: "jetstream",
      bypassed: true,
      controls: {
        manual: 0.44,
        rate_hz: 0.32,
        depth: 0.78,
        feedback: 0.52,
        mix: 0.62,
      },
    },
    {
      id: "fuzz",
      device: "muffin",
      bypassed: true,
      controls: {
        sustain: 0.7,
        tone: 0.46,
        level: 0.45,
      },
    },
    {
      id: "transparent-drive",
      device: "minotaur",
      bypassed: true,
      controls: {
        gain: 0.42,
        treble: 0.61,
        output: 0.58,
      },
    },
    {
      id: "dual-drive",
      device: "monarch",
      bypassed: true,
      controls: {
        gain: 0.48,
        tone: 0.57,
        output: 0.62,
      },
    },
    {
      id: "distortion",
      device: "godess-one",
      bypassed: true,
      controls: {
        distortion: 0.64,
        tone: 0.47,
        level: 0.52,
        mode: "custom",
      },
    },
  ],

  fx_loop: [
    {
      id: "analog-chorus",
      device: "celeste",
      bypassed: true,
      controls: {
        rate_hz: 0.72,
        depth: 0.72,
        tone: 0.58,
        mix: 0.48,
      },
    },
    {
      id: "analog-delay",
      device: "brigade",
      bypassed: true,
      controls: {
        time_ms: 320.0,
        repeats: 0.46,
        tone: 0.38,
        mix: 0.34,
      },
    },
    {
      id: "amp-trem",
      device: "dartford",
      bypassed: true,
      controls: {
        rate_hz: 10.2,
        depth: 1.0,
        level: 1.0,
        wave: "sine",
      },
    },
    {
      id: "spring-reverb",
      device: "springfield",
      bypassed: true,
      controls: {
        dwell: 0.48,
        tone: 0.58,
        mix: 0.26,
      },
    },
  ],

  amp: {
    model: "nox30",
    bypassed: false,
    controls: {
      volume: 0.58,
      bass: 0.56,
      treble: 0.58,
      cut: 0.44,
      drive: 0.24,
      presence: 0.34,
      sag: 0.46,
    },
  },

  cab: {
    ir: "embedded-v30",
    bypassed: false,
  },
}
