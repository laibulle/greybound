{
  // Rig only: no input device, output device, monitor, or render settings.
  name: "muon-nox30",

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: "envelope-filter",
      device: "muon",
      bypassed: false,
      controls: {
        sensitivity: 0.64,
        range: 0.68,
        resonance: 0.52,
        mix: 0.86,
      },
    },
  ],

  amp: {
    model: "nox30",
    bypassed: false,
    controls: {
      volume: 0.56,
      bass: 0.52,
      treble: 0.61,
      cut: 0.41,
      drive: 0.16,
      presence: 0.34,
      sag: 0.42,
    },
  },

  cab: {
    ir: "embedded-v30",
    bypassed: false,
  },
}
