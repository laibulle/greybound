{
  // Rig only: no input device, output device, monitor, or render settings.
  name: 'minotaur-nox30',

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: 'overdrive',
      device: 'minotaur',
      bypassed: false,
      controls: {
        gain: 0.42,
        treble: 0.61,
        output: 0.58,
      },
    },
  ],

  amp: {
    model: 'nox30',
    bypassed: false,
    controls: {
      volume: 0.58,
      bass: 0.54,
      treble: 0.59,
      cut: 0.43,
      drive: 0.20,
      presence: 0.35,
      sag: 0.45,
    },
  },
}
