    },
  ],

  amp: {
    model: 'nox30',
    bypassed: false,
    controls: {
      volume: 0.50,
      bass: 0.52,
      treble: 0.58,
      cut: 0.48,
      drive: 0.18,
      presence: 0.34,
      sag: 0.46,
    },
  },
}
