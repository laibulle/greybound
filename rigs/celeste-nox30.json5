{
  // Rig only: no input device, output device, monitor, or render settings.
  name: "celeste-nox30",

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: "analog-chorus",
      device: "celeste",
      bypassed: false,
      controls: {
        rate_hz: 0.72,
        depth: 0.72,
        tone: 0.58,
        mix: 0.48,
      },
    },
  ],

  amp: {
    model: "nox30",
    bypassed: false,
    controls: {
      volume: 0.52,
      bass: 0.52,
      treble: 0.62,
      cut: 0.42,
      drive: 0.12,
      presence: 0.34,
      sag: 0.42,
    },
  },

  cab: {
    ir: "embedded-v30",
    bypassed: false,
  },
}
