{
  // Rig only: no input device, output device, monitor, or render settings.
  name: "jetstream-nox30",

  chain: {
    cable_capacitance_pf: 470,
  },

  pre_amp: [
    {
      id: "bbd-flanger",
      device: "jetstream",
      bypassed: false,
      controls: {
        manual: 0.44,
        rate_hz: 0.32,
        depth: 0.78,
        feedback: 0.52,
        mix: 0.62,
      },
    },
  ],

  amp: {
    model: "nox30",
    bypassed: false,
    controls: {
      volume: 0.54,
      bass: 0.52,
      treble: 0.60,
      cut: 0.43,
      drive: 0.18,
      presence: 0.32,
      sag: 0.44,
    },
  },

  cab: {
    ir: "embedded-v30",
    bypassed: false,
  },
}
