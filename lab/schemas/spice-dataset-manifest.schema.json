{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greybound.local/schemas/spice-dataset-manifest.schema.json",
  "title": "Greybound SPICE Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "fixture_id",
    "cell_kind",
    "created_at",
    "generator",
    "spice",
    "circuit",
    "sample_rate_hz",
    "stimuli",
    "targets",
    "splits",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "dataset_id": { "type": "string", "minLength": 1 },
    "fixture_id": { "type": "string", "minLength": 1 },
    "cell_kind": {
      "type": "string",
      "enum": [
        "triode_gain_stage",
        "cathode_follower",
        "diode_clipper",
        "tone_network",
        "sag_cell",
        "bbd_cell",
        "jfet_variable_resistance",
        "other"
      ]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_revision"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "git_revision": { "type": "string" }
      }
    },
    "spice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "version"],
      "properties": {
        "engine": { "type": "string" },
        "version": { "type": "string" },
        "options": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      }
    },
    "circuit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "netlist_sha256",
        "source_impedance_ohm",
        "load_impedance_ohm",
        "components"
      ],
      "properties": {
        "netlist_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "source_impedance_ohm": { "type": "number" },
        "load_impedance_ohm": { "type": "number" },
        "operating_point": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "components": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      }
    },
    "sample_rate_hz": { "type": "integer", "minimum": 1 },
    "oversampling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "factor": { "type": "integer", "minimum": 1 },
        "filter": { "type": "string" }
      }
    },
    "stimuli": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "sha256"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "sine_level_sweep",
              "settled_sine",
              "log_sweep",
              "two_tone_imd",
              "pluck",
              "burst",
              "guitar_di",
              "other"
            ]
          },
          "path": { "type": "string" },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node", "unit"],
        "properties": {
          "node": { "type": "string" },
          "unit": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["input", "output", "state", "reference"]
          }
        }
      }
    },
    "splits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "validation", "test"],
      "properties": {
        "train": { "type": "array", "items": { "type": "string" } },
        "validation": { "type": "array", "items": { "type": "string" } },
        "test": { "type": "array", "items": { "type": "string" } },
        "policy": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["input", "output", "metadata", "plot", "report", "netlist", "other"]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
