{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greybound.local/schemas/external-inputs-manifest.schema.json",
  "title": "External Input Audio Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "source_url",
    "retrieved_at",
    "license_notes",
    "files"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "license_notes": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "size_bytes",
          "github_sha",
          "source_url",
          "download_url"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "github_sha": {
            "type": "string"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "download_url": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
